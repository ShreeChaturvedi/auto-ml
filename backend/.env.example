# Backend configuration
PORT=4000
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:4173,http://127.0.0.1:5173,http://127.0.0.1:5174,http://127.0.0.1:4173
STORAGE_PATH=storage/projects.json
DATASET_METADATA_PATH=storage/datasets/metadata.json
DATASET_STORAGE_DIR=storage/datasets/files
DATASET_UPLOAD_MAX_MB=300
DOCUMENT_STORAGE_DIR=storage/documents/files
MODEL_METADATA_PATH=storage/models/metadata.json
MODEL_STORAGE_DIR=storage/models/artifacts

# Database configuration
# Example: postgres://user:password@localhost:5432/automl
DATABASE_URL=
# Optional SSL mode: disable | require
PGSSLMODE=disable
# Connection pool sizing
PG_POOL_MIN=0
PG_POOL_MAX=10

# Query execution / caching defaults
SQL_STATEMENT_TIMEOUT_MS=5000
SQL_MAX_ROWS=1000
SQL_DEFAULT_LIMIT=200
QUERY_CACHE_TTL_MS=300000
QUERY_CACHE_MAX_ENTRIES=500

# Document chunking defaults
DOC_CHUNK_SIZE=500
DOC_CHUNK_OVERLAP=50

# Answer caching
ANSWER_CACHE_TTL_MS=120000

# Execution (Python runtime)
DOCKER_ENABLED=true
DOCKER_IMAGE=automl-python-runtime:latest
EXECUTION_NETWORK=bridge
EXECUTION_AUTO_BUILD_IMAGE=true
EXECUTION_TIMEOUT_MS=30000
EXECUTION_MAX_MEMORY_MB=2048
EXECUTION_MAX_CPU_PERCENT=100
EXECUTION_TMPFS_MB=1024
EXECUTION_DOCKER_PLATFORM=
EXECUTION_WORKSPACE_DIR=storage/workspaces

# Authentication
JWT_SECRET=dev-secret-change-in-production
BCRYPT_ROUNDS=12
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
FRONTEND_URL=http://localhost:5173

# Email (SMTP)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=AutoML Toolchain <noreply@example.com>

# OpenAI LLM configuration
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_DEFAULT_MODEL=gpt-5.4
OPENAI_NL2SQL_MODEL=gpt-5-mini
LLM_TIMEOUT_MS=60000
PREPROCESSING_LLM_TIMEOUT_MS=120000
PREPROCESSING_THINKING_LLM_TIMEOUT_MS=180000
NL2SQL_TIMEOUT_MS=25000
NL2SQL_MAX_TABLES_CONTEXT=8
NL2SQL_MAX_COLUMNS_PER_TABLE=40
NL2SQL_WARN_CONFIDENCE_THRESHOLD=0.72
