    "http-proxy-middleware": "^3.0.5",
    "jsonwebtoken": "^9.0.3",
    "mammoth": "^1.11.0",
    "multer": "^2.1.1",
    "nodemailer": "^8.0.4",
    "openai": "^6.27.0",
