    "@types/multer": "^1.4.11",
    "@types/node": "^22.9.0",
    "@types/nodemailer": "^7.0.11",
    "@types/pg": "^8.15.6",
    "@types/supertest": "^6.0.3",
    "@types/ws": "^8.5.14",
    "autocannon": "^8.0.0",
    "eslint": "^9.36.0",
    "eslint-config-prettier": "^9.1.0",
