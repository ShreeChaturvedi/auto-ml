# Copy to a private file outside git, then `set -a; source ...; set +a`.

# Local CLI auth state for Codex/GCloud. Keep this outside the repo if you prefer.
CLOUDSDK_CONFIG=/tmp/automl-gcloud-config
VERCEL_GLOBAL_CONFIG=/tmp/automl-vercel-config

# Google Cloud project + VM
PROJECT_ID=automl-494107
REGION=us-east1
ZONE=us-east1-b
INSTANCE_NAME=automl-beta
ADDRESS_NAME=automl-beta-ip
MACHINE_TYPE=e2-standard-4
BOOT_DISK_SIZE_GB=100
IMAGE_FAMILY=ubuntu-2404-lts-amd64
IMAGE_PROJECT=ubuntu-os-cloud

# Backend public hostname chosen for the beta
DUCKDNS_HOST=automl.duckdns.org
DUCKDNS_DOMAIN=automl
DUCKDNS_TOKEN=

# Frontend public hostname after the first personal Vercel deploy
FRONTEND_URL=https://agentic-automl-platform.vercel.app
