---
const productLinks = [
  { label: 'Features',     href: '#features' },
  { label: 'How it works', href: '#how-it-works' },
  { label: 'Integrations', href: '#ecosystem' },
  { label: 'Changelog',    href: '#',  comingSoon: true },
  { label: 'Roadmap',      href: '#',  comingSoon: true },
];

const team = [
  { name: 'Shree Chaturvedi', href: 'https://www.linkedin.com/in/chaturs/' },
  { name: 'Ayush Yadav',      href: 'https://www.linkedin.com/in/ayush-yadav-developer/' },
];

const resourceLinks = [
  { label: 'Docs',       href: '#', comingSoon: true },
  { label: 'GitLab repo', href: 'https://gitlab.csi.miamioh.edu/2026-senior-design-projects/ai-augmented-automl-toolchain/ai-augmented-auto-ml-toolchain' },
  { label: 'Security',   href: '#', comingSoon: true },
  { label: 'Privacy',    href: '#', comingSoon: true },
  { label: 'Contact',    href: 'mailto:chaturs@miamioh.edu' },
];
---

<footer class="footer">
  <div class="footer-columns">
    <div class="footer-brand">
      <div class="footer-brand-row">
        <p class="footer-wordmark">Agentic AutoML Platform</p>
        <a
          class="footer-brand-repo"
          href="https://gitlab.csi.miamioh.edu/2026-senior-design-projects/ai-augmented-automl-toolchain/ai-augmented-auto-ml-toolchain"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="GitLab repository"
        >
          <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M22.749 9.769 21.564 5.646c-.025-.075-.05-.125-.075-.2L19.039.997a.62.62 0 0 0-.65-.4.62.62 0 0 0-.55.45l-2.3 7.05H8.484L6.159 1.047a.62.62 0 0 0-.55-.45.62.62 0 0 0-.65.4L2.509 5.446c-.025.05-.05.125-.075.2L1.249 9.769a.877.877 0 0 0 .325.975L12 18.544l10.449-7.8a.88.88 0 0 0 .3-.975Z"/>
          </svg>
        </a>
      </div>
      <p class="footer-builtby">
        <span class="footer-builtby-label">Built by</span>
        {team.map((person, i) => (
          <Fragment>
            <a
              class="footer-builtby-link"
              href={person.href}
              target="_blank"
              rel="noopener noreferrer"
              aria-label={`${person.name} on LinkedIn`}
            >
              <span>{person.name}</span>
              <svg class="footer-builtby-icon" width="11" height="11" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
              </svg>
            </a>
            {i < team.length - 1 && <span class="footer-builtby-sep">and</span>}
          </Fragment>
        ))}
      </p>
    </div>

    <nav class="footer-nav-col" aria-label="Product">
      <h3 class="footer-col-heading">Product</h3>
      <ul>
        {productLinks.map((link) => (
          <li>
            <a
              href={link.href}
              aria-disabled={link.comingSoon ? 'true' : undefined}
              tabindex={link.comingSoon ? -1 : undefined}
            >
              {link.label}
              {link.comingSoon && <span class="coming-soon"> (coming soon)</span>}
            </a>
          </li>
        ))}
      </ul>
    </nav>

    <nav class="footer-nav-col" aria-label="Resources">
      <h3 class="footer-col-heading">Resources</h3>
      <ul>
        {resourceLinks.map((link) => (
          <li>
            <a
              href={link.href}
              aria-disabled={link.comingSoon ? 'true' : undefined}
              tabindex={link.comingSoon ? -1 : undefined}
            >
              {link.label}
              {link.comingSoon && <span class="coming-soon"> (coming soon)</span>}
            </a>
          </li>
        ))}
      </ul>
    </nav>
  </div>

  <div class="footer-copyright">
    © 2026 Agentic AutoML Platform · All rights reserved.
  </div>

</footer>

<div class="footer-giant-wordmark" aria-hidden="true">
  <svg class="footer-giant-svg" viewBox="0 0 1200 300" preserveAspectRatio="xMidYMid meet">
    <defs>
      <!-- Static metallic gradient for the always-visible base layer stroke.
           Dark at extremes, silver-grey at center — the "brushed metal" tone.
           Peak is intentionally capped well below the shine color (#F7F8F8)
           so the moving shine visibly pops against the base everywhere. -->
      <linearGradient id="agentic-base-grad" gradientUnits="userSpaceOnUse"
                      x1="0" y1="0" x2="1200" y2="0">
        <stop class="agentic-stop-0"     offset="0%" />
        <stop class="agentic-stop-1"     offset="25%" />
        <stop class="agentic-stop-peak"  offset="50%" />
        <stop class="agentic-stop-1"     offset="75%" />
        <stop class="agentic-stop-0"     offset="100%" />
      </linearGradient>

      <!-- Bright window for the sweep mask. 16 % band (42–58 %) matches the
           QA'd width of the hero shimmer at Hero.astro:205-208. -->
      <linearGradient id="agentic-sheen-band" x1="0" y1="0" x2="1" y2="0">
        <stop offset="0%"   stop-color="#000" />
        <stop offset="42%"  stop-color="#000" />
        <stop offset="50%"  stop-color="#fff" />
        <stop offset="58%"  stop-color="#000" />
        <stop offset="100%" stop-color="#000" />
      </linearGradient>

      <!-- Mask: white = shine visible, black = only base visible.
           x-region (-200 to +1400) covers the text's horizontal stroke extent.
           y-region (-200 to +500) covers the full vertical glyph extent —
           font-size 483 centered at y=150 means glyphs reach well past the
           viewBox's y=0..300, so the mask region AND the inner band rect
           must both extend vertically or the top/bottom of the shine clips.
           Band gradient varies only in x, so vertical stretch doesn't distort it. -->
      <mask id="agentic-shine-mask" maskUnits="userSpaceOnUse"
            x="-200" y="-200" width="1600" height="700">
        <g class="agentic-sheen-wrap">
          <rect x="-1200" y="-200" width="2400" height="700"
                fill="url(#agentic-sheen-band)" />
        </g>
      </mask>
    </defs>

    <!-- Layer 1: metallic-gradient stroke, always visible.
         fill="var(--surface-0)" keeps letter interiors opaque against
         the page background (preserves the hollow-outline look). -->
    <text class="agentic-base"
          x="50%" y="50%" text-anchor="middle" dominant-baseline="central"
          textLength="1346.4" lengthAdjust="spacingAndGlyphs"
          fill="var(--surface-0)" stroke="url(#agentic-base-grad)" stroke-width="1.5">AGENT</text>

    <!-- Layer 2: solid bright-tone stroke, only visible through the moving mask window.
         Punches a consistent highlight through the metallic base gradient.
         Stroke is themed (dark metallic in light, silver in dark) so the
         brushed-metal effect reads the same way against both page backgrounds. -->
    <text class="agentic-shine"
          x="50%" y="50%" text-anchor="middle" dominant-baseline="central"
          textLength="1346.4" lengthAdjust="spacingAndGlyphs"
          fill="var(--surface-0)" stroke-width="1.5"
          mask="url(#agentic-shine-mask)">AGENT</text>
  </svg>
</div>

<style>
  .footer {
    max-width: 1280px;
    margin: 0 auto;
    padding: 80px 32px 48px;
    position: relative;
    /* No clipping: the giant wordmark deliberately bleeds to the viewport edges */
  }

  .footer-columns {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr;
    gap: 60px;
    margin-bottom: 80px;
  }

  .footer-brand-row {
    display: flex;
    align-items: center;
    gap: 10px;
    margin: 0 0 16px;
  }
  .footer-brand .footer-wordmark {
    font-family: 'Inter Variable', sans-serif;
    font-size: 16px;
    font-weight: 590;
    color: var(--text);
    margin: 0;
  }
  .footer-brand-repo {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: var(--text-muted);
    transition: color var(--dur-fast);
  }
  .footer-brand-repo:hover { color: var(--text); }

  /* "Built by" byline. Named founders > icon soup — humanizes the project
     and gives judges/VCs a direct path to the people behind it. */
  .footer-builtby {
    font-family: 'Inter Variable', sans-serif;
    font-size: 12.5px;
    color: var(--text-muted);
    margin: 0 0 18px;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 6px;
    line-height: 1.4;
  }
  .footer-builtby-label {
    color: var(--text-dim);
  }
  .footer-builtby-link {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    color: var(--text);
    text-decoration: none;
    font-weight: 500;
    border-bottom: 1px solid transparent;
    transition: color var(--dur-fast), border-color var(--dur-fast);
  }
  .footer-builtby-link:hover {
    color: var(--text);
    border-bottom-color: hsl(var(--border-accent, var(--border)));
  }
  .footer-builtby-icon {
    opacity: 0.55;
    transition: opacity var(--dur-fast);
    flex-shrink: 0;
  }
  .footer-builtby-link:hover .footer-builtby-icon { opacity: 1; }
  .footer-builtby-sep {
    color: var(--text-dim);
  }

  .footer-nav-col ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }
  .footer-col-heading {
    font-family: 'Geist Mono Variable', monospace;
    font-size: 11px;
    color: var(--text-dim);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin: 0 0 20px;
  }
  .footer-nav-col a {
    font-family: 'Inter Variable', sans-serif;
    font-size: 13px;
    color: var(--text-muted);
    text-decoration: none;
    transition: color var(--dur-fast);
  }
  .footer-nav-col a:hover { color: var(--text); }
  .footer-nav-col a[aria-disabled='true'] {
    cursor: default;
    pointer-events: none;
  }
  .coming-soon {
    color: var(--text-dim);
    font-size: 11px;
  }

  .footer-copyright {
    padding-top: 24px;
    border-top: 0.8px solid hsl(var(--border));
    font-family: 'Geist Mono Variable', monospace;
    font-size: 12px;
    color: var(--text-dim);
    text-align: center;
    margin-bottom: 64px;
  }

  /* Wordmark lives OUTSIDE the footer. Full-viewport width, fixed box height
     with overflow clipping. The SVG inside is explicitly taller so the top
     ~65% of the text is visible and the bottom ~35% is clipped. Significantly
     oversized since the text is now only "AutoML". */
  .footer-giant-wordmark {
    display: block;
    width: 100vw;
    height: 295px;
    margin: -60px 0 0 0;
    overflow: hidden;
    user-select: none;
    pointer-events: none;
  }
  .footer-giant-svg {
    display: block;
    width: 100vw;
    height: 462px;
    overflow: visible;
    /* Nudge down so caps / stroke antialias clear the overflow clip by a hair */
    transform: translateY(12px);
  }
  .footer-giant-svg text {
    font-family: 'Inter Variable', sans-serif;
    font-weight: 480;
    font-size: 483px;
    letter-spacing: -15px;
    paint-order: stroke;
  }

  /* Themed metallic stops: the base gradient + shine stroke flip values between
     dark/light so the brushed-metal effect survives both themes. CSS custom
     properties resolve on SVG <stop> via the `stop-color` property. */
  .agentic-stop-0    { stop-color: var(--wordmark-base-0); }
  .agentic-stop-1    { stop-color: var(--wordmark-base-1); }
  .agentic-stop-peak { stop-color: var(--wordmark-base-peak); }
  .agentic-shine     { stroke: var(--wordmark-shine); }

  /* Continuous metallic sheen sweep. ~3s matches the prior animation cadence.
     transform-box: fill-box is LOAD-BEARING — it resolves translateX(%) against
     the <g>'s own bbox (2400 units), not the outer viewBox (1200 units). Without
     it, the sweep covers half the distance and the loop restart visibly snaps. */
  .agentic-sheen-wrap {
    transform-box: fill-box;
    transform-origin: 0 0;
    animation: agentic-sheen 3s linear infinite;
  }

  @keyframes agentic-sheen {
    from { transform: translateX(-25%); } /* bright center at world-x = -600, off left */
    to   { transform: translateX(75%);  } /* bright center at world-x = +1800, off right */
  }

  /* motion-policy.css already zeroes animation-duration under prefers-reduced-motion.
     This local rule only pins the resting position of the bright band. */
  @media (prefers-reduced-motion: reduce) {
    .agentic-sheen-wrap {
      animation: none;
      transform: translateX(25%); /* bright center parked at world-x = +600 (center) */
    }
  }
</style>
