---
// Sticky frosted navigation bar.
// Brand: logo + wordmark that loads as "Agentic AutoML ToolChain"
// and collapses to "AutoML" after 1.6s. The brand's width is reserved
// to the long form so nav links / CTA on the right never shift.
---

<header class="nav-root">
  <div class="nav-inner">
    <a href="#top" class="nav-brand">
      <svg
        viewBox="0 0 32 32"
        fill="none"
        xmlns="http://www.w3.org/2000/svg"
        class="nav-logo"
        aria-hidden="true"
      >
        <circle cx="16" cy="4" r="3" fill="currentColor" />
        <path d="M14 8L5 26" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" />
        <path d="M18 8L27 26" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" opacity="0.4" />
        <path d="M9 18H19.5" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" />
      </svg>
      <span class="nav-wordmark" aria-label="Agentic AutoML">
        <span class="nav-wordmark-long">Agentic AutoML ToolChain</span>
        <span class="nav-wordmark-short" aria-hidden="true">AutoML</span>
      </span>
    </a>

    <nav class="nav-links" aria-label="Primary">
      <a href="#product">Product</a>
      <a href="#features">Features</a>
      <a href="#how-it-works">How it works</a>
    </nav>

    <div class="nav-right">
      <a href="/login" class="nav-signin">Sign In</a>
      <a href="/login" class="nav-cta">Get Started</a>
    </div>
  </div>
</header>

<style>
  .nav-root {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    height: 72px;
    background-image: linear-gradient(
      rgba(10, 10, 11, 0.80) 0%,
      rgba(10, 10, 11, 0.76) 100%
    );
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border-bottom: 0.8px solid hsl(var(--border));
  }

  .nav-inner {
    max-width: 1280px;
    height: 100%;
    margin: 0 auto;
    padding: 0 32px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 40px;
  }

  /* ── Brand: logo + wordmark ── */
  .nav-brand {
    display: flex;
    align-items: center;
    gap: 8px;
    text-decoration: none;
    transition: opacity var(--dur-fast) var(--ease-linear-default);
  }
  .nav-brand:hover { opacity: 0.8; }

  .nav-logo {
    width: 24px;
    height: 24px;
    color: var(--text);
    flex-shrink: 0;
  }

  /* Width is reserved to the long form via the inline-block spacer (long).
     The short form is positioned absolutely on top and cross-fades in after
     a delay. Nothing on the right moves — no layout shift. */
  .nav-wordmark {
    position: relative;
    display: inline-block;
    font-family: 'Inter Variable', sans-serif;
    font-size: 16px;
    font-weight: 590;
    color: var(--text);
    letter-spacing: -0.01em;
    white-space: nowrap;
    line-height: 1.2;
  }
  .nav-wordmark-long,
  .nav-wordmark-short {
    display: inline-block;
    white-space: nowrap;
  }
  .nav-wordmark-long {
    animation: nav-brand-long-out 700ms var(--ease-out-quart) 1600ms forwards;
    transform-origin: left center;
  }
  .nav-wordmark-short {
    position: absolute;
    left: 0;
    top: 0;
    opacity: 0;
    transform: translateX(-2px);
    animation: nav-brand-short-in 700ms var(--ease-out-quart) 2000ms forwards;
  }

  @keyframes nav-brand-long-out {
    from { opacity: 1; filter: blur(0); }
    to   { opacity: 0; filter: blur(4px); }
  }
  @keyframes nav-brand-short-in {
    from { opacity: 0; transform: translateX(-2px); filter: blur(4px); }
    to   { opacity: 1; transform: translateX(0);    filter: blur(0);   }
  }

  @media (prefers-reduced-motion: reduce) {
    .nav-wordmark-long  { animation: none; opacity: 0; }
    .nav-wordmark-short { animation: none; opacity: 1; transform: none; filter: none; }
  }

  .nav-links {
    display: flex;
    gap: 8px;
  }

  .nav-links a {
    font-family: 'Geist Mono Variable', ui-monospace, monospace;
    font-size: 13px;
    font-weight: 400;
    color: var(--text-muted);
    text-decoration: none;
    padding: 0 12px;
    height: 32px;
    display: inline-flex;
    align-items: center;
    border-radius: 4px;
    transition: color var(--dur-fast) var(--ease-linear-default);
  }
  .nav-links a:hover { color: var(--text); }

  /* ── Right-side cluster: Sign In + CTA ── */
  .nav-right {
    display: flex;
    align-items: center;
    gap: 16px;
  }

  /* ── Sign In — muted text link, height-matched to CTA ── */
  .nav-signin {
    font-family: 'Inter Variable', sans-serif;
    font-size: 14px;
    font-weight: 510;
    color: var(--text-muted);
    text-decoration: none;
    height: 32px;
    padding: 0 4px;
    display: inline-flex;
    align-items: center;
    border-radius: 4px;
    transition: color var(--dur-fast) var(--ease-linear-default);
  }
  .nav-signin:hover { color: var(--text); }

  /* ── CTA — matches hero "Get Started" ── */
  .nav-cta {
    font-family: 'Inter Variable', sans-serif;
    font-size: 14px;
    font-weight: 510;
    color: #0A0A0B;
    text-decoration: none;
    background: linear-gradient(180deg, #F7F8F8 0%, #E6E6E6 100%);
    padding: 0 16px;
    height: 32px;
    display: inline-flex;
    align-items: center;
    border-radius: 6px;
    box-shadow:
      0 0 0 1px rgba(255, 255, 255, 0.06),
      inset 0 1px 0 rgba(255, 255, 255, 0.5),
      0 1px 2px rgba(0, 0, 0, 0.12);
    transition: filter 180ms ease,
                box-shadow 180ms ease;
  }
  .nav-cta:hover {
    filter: brightness(1.08);
    box-shadow:
      0 0 0 1px rgba(255, 255, 255, 0.1),
      inset 0 1px 0 rgba(255, 255, 255, 0.5),
      0 1px 2px rgba(0, 0, 0, 0.12),
      0 0 12px rgba(255, 255, 255, 0.08);
  }
  .nav-cta:active {
    filter: brightness(0.96);
    box-shadow:
      0 0 0 1px rgba(255, 255, 255, 0.06),
      inset 0 1px 0 rgba(255, 255, 255, 0.3),
      0 0 2px rgba(0, 0, 0, 0.16);
  }
</style>
