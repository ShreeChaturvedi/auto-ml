---
// Gmail header lookalike — logo + search bar + right-side icons.
// Rendered on both `/mock-gmail` (inbox) and `/mock-gmail/email` (detail).
// Styling mirrors Gmail's 2024+ "material 3" shell: light surface, rounded
// search pill, rail icons. Pixel-perfect fidelity isn't the goal; the goal
// is that a viewer sees the shell for a second and says "Gmail", not
// "that obviously-fake Gmail."
---

<header class="gm-header">
  <div class="gm-header-left">
    <button class="gm-icon-btn" aria-label="Main menu">
      <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="#5F6368" stroke-width="2" stroke-linecap="round">
        <path d="M4 6h16M4 12h16M4 18h16"></path>
      </svg>
    </button>
    <div class="gm-logo">
      <svg viewBox="0 0 40 30" width="40" height="30" aria-hidden="true">
        <path d="M3 4l17 11L37 4v23H3z" fill="#EEEEEE" stroke="#C5221F" stroke-width="0.5"></path>
        <path d="M3 4l17 11 17-11H3z" fill="#D93025"></path>
        <path d="M20 15L3 27V4l17 11z" fill="#C5221F"></path>
        <path d="M20 15l17-11v23L20 15z" fill="#EA4335"></path>
      </svg>
      <span class="gm-brand">Gmail</span>
    </div>
  </div>

  <div class="gm-search">
    <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="#5F6368" stroke-width="2" stroke-linecap="round" aria-hidden="true">
      <circle cx="11" cy="11" r="7"></circle>
      <path d="M21 21l-4.35-4.35"></path>
    </svg>
    <input type="text" placeholder="Search mail" aria-label="Search mail" />
    <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="#5F6368" stroke-width="2" stroke-linecap="round" aria-hidden="true">
      <path d="M3 6h18M6 12h12M10 18h4"></path>
    </svg>
  </div>

  <div class="gm-header-right">
    <button class="gm-icon-btn" aria-label="Help">
      <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="#5F6368" stroke-width="2" stroke-linecap="round"><circle cx="12" cy="12" r="9"></circle><path d="M9.5 9.5a2.5 2.5 0 1 1 3.5 2.3c-1 .4-1 1.2-1 2.2M12 17v.01"></path></svg>
    </button>
    <button class="gm-icon-btn" aria-label="Settings">
      <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="#5F6368" stroke-width="2" stroke-linecap="round"><circle cx="12" cy="12" r="3"></circle><path d="M4 12h2M18 12h2M12 4v2M12 18v2M6 6l1.5 1.5M16.5 16.5L18 18M6 18l1.5-1.5M16.5 7.5L18 6"></path></svg>
    </button>
    <div class="gm-avatar" aria-label="Ayush Yadav">AY</div>
  </div>
</header>

<style>
  .gm-header {
    position: sticky;
    top: 0;
    z-index: 10;
    display: grid;
    grid-template-columns: 256px 1fr auto;
    gap: 16px;
    align-items: center;
    height: 64px;
    padding: 0 16px;
    background: #F6F8FC;
    border-bottom: 1px solid #E8EAED;
    font-family:
      -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
  }

  .gm-header-left {
    display: flex;
    align-items: center;
    gap: 12px;
  }
  .gm-logo {
    display: flex;
    align-items: center;
    gap: 8px;
  }
  .gm-brand {
    font-size: 22px;
    color: #5F6368;
    font-family: 'Product Sans', 'Google Sans', -apple-system, sans-serif;
  }

  .gm-icon-btn {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background: transparent;
    border: 0;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background-color 120ms ease-out;
  }
  .gm-icon-btn:hover {
    background: rgba(60, 64, 67, 0.08);
  }

  .gm-search {
    justify-self: start;
    max-width: 720px;
    width: 100%;
    height: 48px;
    padding: 0 20px;
    background: #EAF1FB;
    border-radius: 24px;
    display: flex;
    align-items: center;
    gap: 12px;
  }
  .gm-search input {
    flex: 1;
    border: 0;
    background: transparent;
    outline: none;
    font-size: 15px;
    color: #3C4043;
  }

  .gm-header-right {
    display: flex;
    align-items: center;
    gap: 8px;
  }
  .gm-avatar {
    width: 32px;
    height: 32px;
    border-radius: 50%;
    background: #1A73E8;
    color: #ffffff;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 14px;
    font-weight: 500;
    margin-left: 8px;
  }
</style>
