---
// Painterly new-tab page — visual twin of the Remotion `NewTabBackdrop`
// component. Referenced by Playwright in the signup-verification capture when
// the second tab opens en route to Gmail.
//
// The painterly base image is generated by `video/scripts/make-newtab-bg.sh`
// and checked in so Astro builds don't require a local ImageMagick install.
// CSS overlays add grain, vignette; the search bar + wordmark follow the
// official Google new-tab design language.
import Root from '@/layouts/Root.astro';

const query = Astro.url.searchParams;
const showShortcuts = query.get('shortcuts') === '1';

type Shortcut = { label: string; href: string; color: string; letter: string };

const SHORTCUTS: Shortcut[] = [
  { label: 'Gmail',    href: '/mock-gmail',                 color: '#EA4335', letter: 'M' },
  { label: 'YouTube',  href: 'https://youtube.com',         color: '#FF0000', letter: 'Y' },
  { label: 'Drive',    href: 'https://drive.google.com',    color: '#FBBC05', letter: 'D' },
  { label: 'GitHub',   href: 'https://github.com',          color: '#24292F', letter: 'G' },
  { label: 'Maps',     href: 'https://maps.google.com',     color: '#34A853', letter: 'M' },
];
---

<Root title="New Tab">
  <div class="newtab-page">
    <img class="newtab-painterly" src="/assets/newtab-bg.webp" alt="" aria-hidden="true" />
    <svg class="newtab-grain" width="100%" height="100%" aria-hidden="true">
      <filter id="g"><feTurbulence baseFrequency="1.6" numOctaves="3" seed="5"/></filter>
      <rect width="100%" height="100%" filter="url(#g)"/>
    </svg>
    <div class="newtab-vignette"></div>

    <main class="newtab-content">
      <!-- Google colored-letter wordmark -->
      <div class="gg-wordmark" aria-label="Google">
        <span style="color:#4285F4">G</span><span style="color:#EA4335">o</span><span style="color:#FBBC05">o</span><span style="color:#4285F4">g</span><span style="color:#34A853">l</span><span style="color:#EA4335">e</span>
      </div>

      <!-- Search bar -->
      <label class="gg-search" for="newtab-search-input">
        <!-- Magnifier icon -->
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" aria-hidden="true">
          <path d="M15.5 14h-.79l-.28-.27A6.471 6.471 0 0016 9.5 6.5 6.5 0 109.5 16c1.61 0 3.09-.59 4.23-1.57l.27.28v.79l5 4.99L20.49 19l-4.99-5z" fill="#9aa0a6"/>
        </svg>

        <input id="newtab-search-input" type="text" autocomplete="off" spellcheck="false" autofocus placeholder="Search Google or type a URL" />

        <!-- Google Voice (mic) icon -->
        <button class="gg-ic-btn" type="button" aria-label="Search by voice">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" aria-hidden="true">
            <path d="M12 14a3 3 0 003-3V5a3 3 0 00-6 0v6a3 3 0 003 3z" fill="#4285F4"/>
            <path d="M11 5v6a1 1 0 002 0V5a1 1 0 00-2 0z" fill="#34A853"/>
            <path d="M17 11a5 5 0 01-10 0H5a7 7 0 0014 0h-2z" fill="#EA4335"/>
            <path d="M12 18a7 7 0 007-7h-2a5 5 0 01-5 5v2z" fill="#FBBC05"/>
            <rect x="11" y="18" width="2" height="4" rx="1" fill="#9aa0a6"/>
            <rect x="9" y="21" width="6" height="2" rx="1" fill="#9aa0a6"/>
          </svg>
        </button>

        <!-- Google Lens icon -->
        <button class="gg-ic-btn" type="button" aria-label="Search by image">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" aria-hidden="true">
            <circle cx="12" cy="12" r="3.5" stroke="#4285F4" stroke-width="1.5" fill="none"/>
            <path d="M3 7V5a2 2 0 012-2h2" stroke="#EA4335" stroke-width="1.5" stroke-linecap="round"/>
            <path d="M17 3h2a2 2 0 012 2v2" stroke="#FBBC05" stroke-width="1.5" stroke-linecap="round"/>
            <path d="M21 17v2a2 2 0 01-2 2h-2" stroke="#34A853" stroke-width="1.5" stroke-linecap="round"/>
            <path d="M7 21H5a2 2 0 01-2-2v-2" stroke="#4285F4" stroke-width="1.5" stroke-linecap="round"/>
          </svg>
        </button>
      </label>

      {showShortcuts && (
        <div class="gg-tiles">
          {SHORTCUTS.map((s) => (
            <a href={s.href} class="gg-tile">
              <span class="circle" style={`background:${s.color}`}>{s.letter}</span>
              <span class="label">{s.label}</span>
            </a>
          ))}
        </div>
      )}
    </main>
  </div>

  <script>
    const input = document.getElementById('newtab-search-input') as HTMLInputElement | null;
    input?.addEventListener('keydown', (e) => {
      if (e.key !== 'Enter') return;
      const q = input.value.trim().toLowerCase();
      if (!q) return;
      e.preventDefault();
      if (q.includes('gmail')) {
        window.location.href = '/mock-gmail';
      } else if (q.startsWith('http')) {
        window.location.href = q;
      } else {
        window.location.href = `https://www.google.com/search?q=${encodeURIComponent(q)}`;
      }
    });
  </script>
</Root>

<style>
  html, body { background: #202124; margin: 0; padding: 0; }

  .newtab-page { position: relative; min-height: 100vh; overflow: hidden; }

  .newtab-painterly {
    position: fixed; inset: 0; width: 100%; height: 100%; object-fit: cover;
    filter: saturate(0.88) contrast(1.04) brightness(0.98);
  }

  .newtab-grain {
    position: fixed; inset: 0; pointer-events: none;
    mix-blend-mode: soft-light; opacity: 0.18;
  }

  .newtab-vignette {
    position: fixed; inset: 0; pointer-events: none;
    background: radial-gradient(ellipse at center, transparent 40%, rgba(40,28,20,0.32) 100%);
  }

  .newtab-content {
    position: relative; z-index: 1;
    display: flex; flex-direction: column; align-items: center;
    padding-top: 180px; gap: 22px; min-height: 100vh;
  }

  .gg-wordmark {
    font-family: 'Product Sans','Google Sans',Arial,sans-serif;
    font-size: 92px; font-weight: 400; letter-spacing: -2px; line-height: 1;
    text-shadow: 0 2px 12px rgba(0,0,0,0.15);
    user-select: none;
  }

  .gg-search {
    display: flex; align-items: center; gap: 10px;
    width: 584px; height: 46px; padding: 0 14px;
    background: rgba(255,255,255,0.96); border: 1px solid #dfe1e5;
    border-radius: 24px; cursor: text;
    backdrop-filter: blur(10px);
    transition: box-shadow .15s, border-color .15s;
  }
  .gg-search:hover, .gg-search:focus-within {
    border-color: rgba(223,225,229,0);
    box-shadow: 0 1px 6px rgba(32,33,36,.28);
  }
  .gg-search input {
    flex: 1; border: 0; outline: none; background: transparent;
    font: 16px/24px Arial,sans-serif; color: #202124;
  }
  .gg-search input::placeholder { color: #5f6368; }

  .gg-ic-btn {
    border: 0; background: transparent; padding: 4px; cursor: pointer;
    border-radius: 50%; display: flex; align-items: center; justify-content: center;
    transition: background .15s;
  }
  .gg-ic-btn:hover { background: #f1f3f4; }

  /* Shortcut tiles (?shortcuts=1 only) */
  .gg-tiles { display: flex; gap: 12px; margin-top: 24px; }
  .gg-tile {
    width: 112px; height: 112px; border-radius: 14px;
    background: rgba(255,255,255,0.85); backdrop-filter: blur(8px);
    display: flex; flex-direction: column; align-items: center; justify-content: center;
    gap: 8px; text-decoration: none; color: #202124;
    border: 1px solid rgba(32,33,36,0.08);
    transition: box-shadow .15s;
  }
  .gg-tile:hover { box-shadow: 0 1px 6px rgba(32,33,36,.16); }
  .gg-tile .circle {
    width: 48px; height: 48px; border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    color: white; font-weight: 700; font-size: 18px;
  }
  .gg-tile .label { font: 12px 'Google Sans',Arial,sans-serif; }
</style>
