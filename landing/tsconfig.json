{
  "extends": "astro/tsconfigs/strict",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"]
    },
    "jsx": "react-jsx",
    "jsxImportSource": "react",
    "types": ["astro/client", "vitest/globals"]
  },
  "include": ["src/**/*", "*.config.*"],
  "exclude": ["dist/", "node_modules/"]
}
