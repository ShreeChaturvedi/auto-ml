{
  "name": "ai-augmented-automl-monorepo",
  "private": true,
  "scripts": {
    "install:all": "npm --prefix backend install && npm --prefix frontend install && npm --prefix testing install && npm --prefix landing install && npm --prefix video install && npm --prefix poster install && npm --prefix booklet install",
    "install:landing": "npm --prefix landing install",
    "install:video": "npm --prefix video install",
    "install:poster": "npm --prefix poster install",
    "install:booklet": "npm --prefix booklet install",
    "poster:dev": "npm --prefix poster run dev",
    "poster:build": "npm --prefix poster run build",
    "poster:pdf": "npm --prefix poster run pdf",
    "poster:frames": "npm --prefix poster run frames",
    "booklet:dev": "npm --prefix booklet run dev",
    "booklet:build": "npm --prefix booklet run build",
    "booklet:pdf": "npm --prefix booklet run pdf",
    "dev": "node scripts/dev/run.mjs",
    "dev:ui": "npm --prefix frontend run dev:ui",
    "dev:backend": "npm --prefix backend run dev",
    "dev:landing": "npm --prefix landing run dev",
    "video:dev": "npm --prefix video start",
    "video:build": "npm --prefix video run build",
    "video:build:draft": "npm --prefix video run build:draft",
    "video:voiceover": "npm --prefix video run voiceover",
    "vercel:landing:pull:preview": "npx --yes vercel@51.2.1 pull --yes --environment=preview",
    "vercel:landing:pull:production": "npx --yes vercel@51.2.1 pull --yes --environment=production",
    "vercel:landing:build": "npx --yes vercel@51.2.1 build",
    "vercel:landing:deploy:preview": "npx --yes vercel@51.2.1 deploy --prebuilt --yes --target=preview",
    "vercel:landing:deploy:production": "npx --yes vercel@51.2.1 deploy --prebuilt --yes --target=production",
    "vercel:frontend:whoami": "bash deploy/beta/vercel.sh whoami",
    "vercel:frontend:pull:preview": "cd frontend && ../deploy/beta/vercel.sh pull --yes --environment=preview",
    "vercel:frontend:pull:production": "cd frontend && ../deploy/beta/vercel.sh pull --yes --environment=production",
    "vercel:frontend:build": "cd frontend && ../deploy/beta/vercel.sh build",
    "vercel:frontend:deploy:preview": "cd frontend && ../deploy/beta/vercel.sh deploy --prebuilt --yes --target=preview",
    "vercel:frontend:deploy:production": "cd frontend && ../deploy/beta/vercel.sh deploy --prebuilt --yes --target=production",
    "gcp:enable:compute": "bash deploy/beta/gcp-enable-compute.sh",
    "gcp:reserve:ip": "bash deploy/beta/gcp-reserve-static-ip.sh",
    "gcp:create:vm": "bash deploy/beta/gcp-create-vm.sh",
    "gcp:provision": "bash deploy/beta/gcp-provision.sh",
    "gcp:ssh": "bash deploy/beta/gcp-ssh.sh",
    "gcp:bundle:create": "bash deploy/beta/create-release-bundle.sh",
    "gcp:bundle:upload": "bash deploy/beta/gcp-upload-release-bundle.sh",
    "gcp:env:render": "bash deploy/beta/render-backend-env.sh",
    "gcp:env:upload": "bash deploy/beta/gcp-upload-backend-env.sh",
    "gcp:stage:release": "bash deploy/beta/gcp-stage-release.sh",
    "duckdns:point:gcp": "bash deploy/beta/duckdns-point-to-gcp-ip.sh",
    "build": "npm --prefix backend run build && npm --prefix frontend run build",
    "build:landing": "npm --prefix landing run build",
    "audit": "node scripts/audit.mjs",
    "lint": "npm --prefix backend run lint && npm --prefix frontend run lint",
    "lint:landing": "npm --prefix landing run lint",
    "lint:video": "npm --prefix video run lint",
    "test": "npm --prefix backend test && npm --prefix frontend test",
    "test:backend": "npm --prefix backend test",
    "test:frontend": "npm --prefix frontend test",
    "test:landing": "npm --prefix landing run test",
    "db:migrate": "npm --prefix backend run db:migrate",
    "benchmark": "npm --prefix testing run benchmark",
    "benchmark:preprocessing:mock": "LLM_PROVIDER=mock npm --prefix testing run benchmark -- tests/preprocessing-mock-regression.spec.ts",
    "benchmark:headed": "npm --prefix testing run benchmark:headed",
    "benchmark:api": "npm --prefix backend run benchmark:api",
    "test:preprocessing:burnin": "AUTOML_BENCHMARK_AUTH_BYPASS=true node testing/scripts/preprocessing_mock_burn_in.mjs",
    "eval": "npm --prefix testing run eval"
  }
}
