{
  "name": "video",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "start": "remotion studio",
    "build": "remotion render remotion/index.ts main out/final.mp4 --crf 18",
    "build:draft": "remotion render remotion/index.ts main out/draft.mp4 --crf 28 --scale 0.5 --x264-preset fast",
    "build:only": "remotion render remotion/index.ts main out/partial.mp4",
    "render:lambda": "tsx scripts/render-lambda.mts",
    "voiceover": "tsx scripts/voiceover.mts",
    "capture:landing": "tsx scripts/capture-landing.ts",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "upgrade": "remotion upgrade"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-label": "^2.1.7",
    "@radix-ui/react-slot": "^1.2.3",
    "@remotion/bundler": "4.0.448",
    "@remotion/cli": "4.0.448",
    "@remotion/fonts": "4.0.448",
    "@remotion/google-fonts": "4.0.448",
    "@remotion/media-utils": "4.0.448",
    "@remotion/renderer": "4.0.448",
    "@remotion/tailwind": "4.0.448",
    "@remotion/transitions": "4.0.448",
    "@remotion/zod-types": "4.0.448",
    "@tailwindcss/typography": "^0.5.19",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.544.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-hook-form": "^7.63.0",
    "react-router-dom": "^7.13.1",
    "remotion": "4.0.448",
    "shiki": "^1.24.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.3.1",
    "tailwindcss-animate": "^1.0.7",
    "zod": "4.3.6",
    "zustand": "^5.0.8"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.0",
    "@remotion/eslint-config-flat": "4.0.448",
    "@types/react": "19.2.7",
    "@types/react-dom": "19.2.3",
    "autoprefixer": "^10.4.21",
    "eslint": "9.19.0",
    "postcss": "^8.5.6",
    "prettier": "3.8.1",
    "prettier-plugin-organize-imports": "3.2.3",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.2",
    "typescript": "5.9.3",
    "vitest": "^3.2.4"
  }
}
