{
  "compilerOptions": {
    "target": "ESNext",
    "useDefineForClassFields": true,
    "lib": ["DOM", "DOM.Iterable", "ESNext"],
    "allowJs": false,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "strictNullChecks": true,
    "alwaysStrict": true,
    "noUncheckedIndexedAccess": true,
    "noUnusedLocals": true,
    "types": ["node"],
    "paths": {
      "@/stores/authStore":               ["./src/frontend-bridge/mockAuthStore.ts"],
      "@/stores/projectStore":            ["./src/frontend-bridge/mockProjectStore.ts"],
      "@/stores/notebookStore":           ["./src/frontend-bridge/mockNotebookStore.ts"],
      "@/lib/api/auth":                   ["./src/frontend-bridge/mockAuthApi.ts"],
      "@/lib/api/projects":               ["./src/frontend-bridge/mockProjectApi.ts"],
      "@/components/ui/shooting-stars":   ["./src/frontend-bridge/stars/ShootingStars.tsx"],
      "@/components/ui/stars-background": ["./src/frontend-bridge/stars/StarsBackground.tsx"],
      "@/components/projects/ProjectDialog": ["./src/frontend-bridge/mockProjectDialog.tsx"],
      "@/*":                              ["../frontend/src/*"],
      "*":                                ["./node_modules/@types/*", "./node_modules/*"]
    }
  },
  "include": ["remotion", "config", "scripts", "src", "fixtures"],
  "exclude": ["remotion.config.ts", "node_modules", "out"]
}
